{
  "contract": {
    "name": "hausman-hub-capabilities",
    "version": 1
  },
  "api": {
    "major_version": 1,
    "base_path": "/api/hausman_hub/v1"
  },
  "capabilities": {
    "climate_home": {
      "available": true,
      "path": "/api/hausman_hub/v1/home",
      "method": "GET",
      "response_contract": {
        "name": "hausman-hub-home",
        "version": 12
      }
    },
    "automatic_contours": {
      "available": true,
      "path": "/api/hausman_hub/v1/contours",
      "method": "GET",
      "response_contract": {
        "name": "hausman-hub-contours",
        "version": 7
      }
    },
    "contour_settings_apply": {
      "available": true,
      "preview_path": "/api/hausman_hub/v1/contours/apply-preview",
      "path": "/api/hausman_hub/v1/contours/apply",
      "method": "POST",
      "requires_confirmation": true,
      "request_contract": {
        "name": "hausman-hub-contour-apply-request",
        "version": 1
      },
      "response_contract": {
        "name": "hausman-hub-contour-apply-receipt",
        "version": 1
      }
    },
    "temporary_room_temperature": {
      "available": true,
      "path": "/api/hausman_hub/v1/contours/temporary-temperature",
      "method": "POST",
      "requires_confirmation": true,
      "request_contract": {
        "name": "hausman-hub-temporary-temperature-request",
        "version": 1
      },
      "response_contract": {
        "name": "hausman-hub-contour-apply-receipt",
        "version": 1
      }
    },
    "climate_actions": {
      "available": true,
      "path": "/api/hausman_hub/v1/actions",
      "method": "POST",
      "request_contract": {
        "name": "hausman-hub-climate-action-request",
        "version": 1
      },
      "response_contract": {
        "name": "hausman-hub-operation",
        "version": 1
      }
    },
    "operation_receipts": {
      "available": true,
      "path": "/api/hausman_hub/v1/operations",
      "method": "POST",
      "query_contract": {
        "name": "hausman-hub-climate-operation-query",
        "version": 1
      },
      "response_contract": {
        "name": "hausman-hub-operation",
        "version": 1
      }
    }
  }
}
