{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hausman.local/hasc/contracts/v1/contour-apply-request.schema.json",
  "title": "HASC contour apply request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "contour_id", "confirm"],
  "properties": {
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"
    },
    "contour_id": {"const": "climate"},
    "confirm": {"const": true}
  }
}
