{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hausman.local/hasc/contracts/v1/climate-draft.schema.json",
  "title": "Черновик климатического контура HASC v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "generated_at",
    "snapshot_revision",
    "draft_revision",
    "status",
    "save_allowed",
    "validation_required",
    "display_names",
    "name",
    "mode",
    "rooms",
    "summary"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "hausman-hasc-climate-draft"
        },
        "version": {
          "const": 1
        }
      }
    },
    "generated_at": {
      "type": "integer",
      "minimum": 0
    },
    "snapshot_revision": {
      "$ref": "#/$defs/revision"
    },
    "draft_revision": {
      "$ref": "#/$defs/revision"
    },
    "status": {
      "const": "created"
    },
    "save_allowed": {
      "const": false
    },
    "validation_required": {
      "const": true
    },
    "display_names": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modes",
        "strategies"
      ],
      "properties": {
        "modes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "observe",
            "automatic"
          ],
          "properties": {
            "observe": {
              "const": "Только наблюдение"
            },
            "automatic": {
              "const": "Автоматическое управление"
            }
          }
        },
        "strategies": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "soft",
            "normal",
            "aggressive"
          ],
          "properties": {
            "soft": {
              "const": "Плавно"
            },
            "normal": {
              "const": "Обычно"
            },
            "aggressive": {
              "const": "Быстро"
            }
          }
        }
      }
    },
    "name": {
      "$ref": "#/$defs/name"
    },
    "mode": {
      "enum": [
        "observe",
        "automatic"
      ]
    },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/room"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "room_count",
        "device_count"
      ],
      "properties": {
        "room_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128
        },
        "device_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 512
        }
      }
    }
  },
  "$defs": {
    "revision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate_[0-9]{4}$"
    },
    "device_type": {
      "enum": [
        "air_conditioner",
        "radiator_thermostat",
        "humidifier",
        "floor_heating",
        "temperature_sensor",
        "humidity_sensor"
      ]
    },
    "strategy": {
      "enum": [
        "soft",
        "normal",
        "aggressive"
      ]
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_temperature",
        "target_humidity",
        "strategy"
      ],
      "properties": {
        "target_temperature": {
          "type": "number",
          "minimum": 18,
          "maximum": 28,
          "multipleOf": 0.5
        },
        "target_humidity": {
          "type": "integer",
          "minimum": 30,
          "maximum": 70,
          "multipleOf": 5
        },
        "strategy": {
          "$ref": "#/$defs/strategy"
        }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "name",
        "type",
        "type_name"
      ],
      "properties": {
        "candidate_id": {
          "$ref": "#/$defs/candidate_id"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "type": {
          "$ref": "#/$defs/device_type"
        },
        "type_name": {
          "enum": [
            "Кондиционер",
            "Термоголовка радиатора",
            "Увлажнитель",
            "Тёплый пол",
            "Датчик температуры",
            "Датчик влажности"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "air_conditioner"
              }
            }
          },
          "then": {
            "properties": {
              "type_name": {
                "const": "Кондиционер"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "radiator_thermostat"
              }
            }
          },
          "then": {
            "properties": {
              "type_name": {
                "const": "Термоголовка радиатора"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "humidifier"
              }
            }
          },
          "then": {
            "properties": {
              "type_name": {
                "const": "Увлажнитель"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "floor_heating"
              }
            }
          },
          "then": {
            "properties": {
              "type_name": {
                "const": "Тёплый пол"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "temperature_sensor"
              }
            }
          },
          "then": {
            "properties": {
              "type_name": {
                "const": "Датчик температуры"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "humidity_sensor"
              }
            }
          },
          "then": {
            "properties": {
              "type_name": {
                "const": "Датчик влажности"
              }
            }
          }
        }
      ]
    },
    "room": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "targets",
        "devices"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "targets": {
          "$ref": "#/$defs/targets"
        },
        "devices": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/device"
          }
        }
      }
    }
  }
}
