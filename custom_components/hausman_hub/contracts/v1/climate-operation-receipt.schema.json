{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shumkiiv/hausmanhub_hacs/contracts/v1/climate-operation-receipt.schema.json",
  "title": "HausmanHub climate operation receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "operation_id", "request_id", "action", "room_id", "device_id", "status", "execution", "created_at", "updated_at", "known"],
  "properties": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "hausman-hub-operation"},
        "version": {"const": 1}
      }
    },
    "operation_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
    "request_id": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
    "action": {"type": ["string", "null"]},
    "room_id": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
    "device_id": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
    "status": {"enum": ["accepted", "pending", "confirmed", "rejected", "timed_out", "unknown"]},
    "execution": {"enum": ["shadow", "canary", null]},
    "created_at": {"type": ["integer", "null"], "minimum": 0},
    "updated_at": {"type": ["integer", "null"], "minimum": 0},
    "known": {"type": "boolean"}
  },
  "allOf": [
    {
      "if": {"properties": {"known": {"const": false}}, "required": ["known"]},
      "then": {
        "properties": {
          "request_id": {"const": null},
          "action": {"const": null},
          "room_id": {"const": null},
          "device_id": {"const": null},
          "status": {"const": "unknown"},
          "execution": {"const": null},
          "created_at": {"const": null},
          "updated_at": {"const": null}
        }
      }
    },
    {
      "if": {"properties": {"known": {"const": true}}, "required": ["known"]},
      "then": {
        "properties": {
          "request_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"},
          "action": {"type": "string"},
          "room_id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
          "status": {"enum": ["accepted", "pending", "confirmed", "rejected", "timed_out"]},
          "execution": {"enum": ["shadow", "canary"]},
          "created_at": {"type": "integer", "minimum": 0},
          "updated_at": {"type": "integer", "minimum": 0}
        }
      }
    }
  ]
}
