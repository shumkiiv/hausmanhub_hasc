{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shumkiiv/hausmanhub_hacs/contracts/v8/climate-home.schema.json",
  "title": "HausmanHub climate home with active target, saved profiles, and factual room state v8",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "generated_at",
    "climate",
    "display_names",
    "rooms",
    "contours",
    "reconciliation"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "hausman-hub-home"
        },
        "version": {
          "const": 8
        }
      }
    },
    "generated_at": {
      "type": "integer",
      "minimum": 0
    },
    "climate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fresh",
        "commands_enabled"
      ],
      "properties": {
        "fresh": {
          "type": "boolean"
        },
        "commands_enabled": {
          "type": "boolean"
        }
      }
    },
    "rooms": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/home_room"
      }
    },
    "contours": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/contour"
      }
    },
    "reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matches",
        "matched_device_ids",
        "missing_device_ids",
        "room_mismatch_device_ids",
        "unregistered_device_count"
      ],
      "properties": {
        "matches": {
          "type": "boolean"
        },
        "matched_device_ids": {
          "$ref": "#/$defs/stable_ids"
        },
        "missing_device_ids": {
          "$ref": "#/$defs/stable_ids"
        },
        "room_mismatch_device_ids": {
          "$ref": "#/$defs/stable_ids"
        },
        "unregistered_device_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 512
        }
      }
    },
    "display_names": {
      "$ref": "#/$defs/display_names"
    }
  },
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "stable_ids": {
      "type": "array",
      "maxItems": 512,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stable_id"
      }
    },
    "nullable_number": {
      "type": [
        "number",
        "null"
      ]
    },
    "home_room": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "temperature",
        "humidity",
        "target_temperature",
        "target_humidity",
        "mode",
        "active_target",
        "saved_profiles",
        "actual",
        "authority_eligible",
        "control",
        "devices"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "temperature": {
          "$ref": "#/$defs/nullable_number"
        },
        "humidity": {
          "$ref": "#/$defs/nullable_number"
        },
        "target_temperature": {
          "$ref": "#/$defs/nullable_number"
        },
        "target_humidity": {
          "$ref": "#/$defs/nullable_number"
        },
        "mode": {
          "enum": [
            "automatic",
            "manual",
            "unknown"
          ]
        },
        "active_target": {
          "$ref": "#/$defs/active_target"
        },
        "saved_profiles": {
          "$ref": "#/$defs/saved_profiles"
        },
        "actual": {
          "$ref": "#/$defs/room_actual"
        },
        "authority_eligible": {
          "type": "boolean"
        },
        "control": {
          "$ref": "#/$defs/room_control"
        },
        "devices": {
          "type": "array",
          "maxItems": 512,
          "items": {
            "$ref": "#/$defs/device"
          }
        }
      }
    },
    "active_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temperature",
        "humidity",
        "strategy"
      ],
      "properties": {
        "temperature": {
          "$ref": "#/$defs/nullable_number"
        },
        "humidity": {
          "$ref": "#/$defs/nullable_number"
        },
        "strategy": {
          "enum": [
            "soft",
            "normal",
            "aggressive",
            "unknown"
          ]
        }
      }
    },
    "saved_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temperature",
        "humidity",
        "strategy"
      ],
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 18,
          "maximum": 28,
          "multipleOf": 0.5
        },
        "humidity": {
          "type": "integer",
          "minimum": 30,
          "maximum": 70,
          "multipleOf": 5
        },
        "strategy": {
          "enum": [
            "soft",
            "normal",
            "aggressive"
          ]
        }
      }
    },
    "saved_profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active",
        "day",
        "night"
      ],
      "properties": {
        "active": {
          "enum": [
            "day",
            "night",
            null
          ]
        },
        "day": {
          "anyOf": [
            {
              "$ref": "#/$defs/saved_profile"
            },
            {
              "type": "null"
            }
          ]
        },
        "night": {
          "anyOf": [
            {
              "$ref": "#/$defs/saved_profile"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "active"
            ],
            "properties": {
              "active": {
                "type": "null"
              }
            }
          },
          "then": {
            "properties": {
              "day": {
                "type": "null"
              },
              "night": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "day": {
                "$ref": "#/$defs/saved_profile"
              },
              "night": {
                "$ref": "#/$defs/saved_profile"
              }
            }
          }
        }
      ]
    },
    "room_actual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_status",
        "temperature",
        "humidity",
        "mode"
      ],
      "properties": {
        "data_status": {
          "enum": [
            "current",
            "stale",
            "unavailable"
          ]
        },
        "temperature": {
          "$ref": "#/$defs/nullable_number"
        },
        "humidity": {
          "$ref": "#/$defs/nullable_number"
        },
        "mode": {
          "enum": [
            "automatic",
            "manual",
            "unknown"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "data_status"
            ],
            "properties": {
              "data_status": {
                "const": "unavailable"
              }
            }
          },
          "then": {
            "properties": {
              "temperature": {
                "type": "null"
              },
              "humidity": {
                "type": "null"
              },
              "mode": {
                "const": "unknown"
              }
            }
          }
        }
      ]
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "control_scope",
        "capabilities",
        "available",
        "state"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "kind": {
          "enum": [
            "air_conditioner",
            "radiator_thermostat",
            "humidifier",
            "floor_heating",
            "temperature_sensor",
            "humidity_sensor"
          ]
        },
        "control_scope": {
          "enum": [
            "observed",
            "canary",
            "managed"
          ]
        },
        "capabilities": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "enum": [
              "power",
              "target_temperature",
              "target_humidity",
              "hvac_mode",
              "fan_mode",
              "auto_manual",
              "target_strategy",
              "cooldown",
              "physical_feedback"
            ]
          }
        },
        "available": {
          "type": "boolean"
        },
        "state": {
          "enum": [
            "working",
            "idle",
            "off",
            "unavailable",
            "unknown"
          ]
        }
      }
    },
    "room_action": {
      "enum": [
        "set_room_target",
        "turn_room_off"
      ]
    },
    "blocked_reason": {
      "enum": [
        "bridge_disabled",
        "shadow_only",
        "room_not_selected",
        "state_stale",
        "registry_mismatch",
        "authority_not_ready",
        "device_unavailable",
        "actions_unsupported",
        "evidence_not_ready",
        "operation_pending"
      ]
    },
    "temperature_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "required",
        "minimum",
        "maximum",
        "step",
        "unit"
      ],
      "properties": {
        "type": {
          "const": "number"
        },
        "required": {
          "const": true
        },
        "minimum": {
          "const": 18
        },
        "maximum": {
          "const": 28
        },
        "step": {
          "const": 0.5
        },
        "unit": {
          "const": "°C"
        }
      }
    },
    "action_inputs": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 1,
      "properties": {
        "set_room_target": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target_temperature"
          ],
          "properties": {
            "target_temperature": {
              "$ref": "#/$defs/temperature_input"
            }
          }
        }
      }
    },
    "target_field_presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description"
      ],
      "properties": {
        "title": {
          "const": "Желаемая температура"
        },
        "description": {
          "const": "Значение, которое должен поддерживать климатический контур."
        }
      }
    },
    "target_action_presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "confirmation_required",
        "fields"
      ],
      "properties": {
        "title": {
          "const": "Установить температуру"
        },
        "description": {
          "const": "Изменить желаемую температуру в комнате."
        },
        "confirmation_required": {
          "const": false
        },
        "fields": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "target_temperature"
          ],
          "properties": {
            "target_temperature": {
              "$ref": "#/$defs/target_field_presentation"
            }
          }
        }
      }
    },
    "off_action_presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "confirmation_required",
        "fields"
      ],
      "properties": {
        "title": {
          "const": "Выключить климат"
        },
        "description": {
          "const": "Остановить поддержание климата в комнате."
        },
        "confirmation_required": {
          "const": true
        },
        "fields": {
          "type": "object",
          "additionalProperties": false,
          "maxProperties": 0
        }
      }
    },
    "action_presentations": {
      "type": "object",
      "additionalProperties": false,
      "maxProperties": 2,
      "properties": {
        "set_room_target": {
          "$ref": "#/$defs/target_action_presentation"
        },
        "turn_room_off": {
          "$ref": "#/$defs/off_action_presentation"
        }
      }
    },
    "room_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "actions",
        "action_inputs",
        "action_presentations",
        "blocked_reasons"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "actions": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/room_action"
          }
        },
        "action_inputs": {
          "$ref": "#/$defs/action_inputs"
        },
        "action_presentations": {
          "$ref": "#/$defs/action_presentations"
        },
        "blocked_reasons": {
          "type": "array",
          "maxItems": 10,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/blocked_reason"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": [
              "enabled"
            ]
          },
          "then": {
            "properties": {
              "actions": {
                "const": [
                  "set_room_target",
                  "turn_room_off"
                ]
              },
              "blocked_reasons": {
                "maxItems": 0
              }
            }
          },
          "else": {
            "properties": {
              "blocked_reasons": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "actions": {
                "contains": {
                  "const": "set_room_target"
                }
              }
            },
            "required": [
              "actions"
            ]
          },
          "then": {
            "properties": {
              "action_inputs": {
                "required": [
                  "set_room_target"
                ]
              },
              "action_presentations": {
                "required": [
                  "set_room_target"
                ]
              }
            }
          },
          "else": {
            "properties": {
              "action_inputs": {
                "maxProperties": 0
              },
              "action_presentations": {
                "not": {
                  "required": [
                    "set_room_target"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "actions": {
                "contains": {
                  "const": "turn_room_off"
                }
              }
            },
            "required": [
              "actions"
            ]
          },
          "then": {
            "properties": {
              "action_presentations": {
                "required": [
                  "turn_room_off"
                ]
              }
            }
          },
          "else": {
            "properties": {
              "action_presentations": {
                "not": {
                  "required": [
                    "turn_room_off"
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "comfort_values": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temperature",
        "humidity",
        "strategy"
      ],
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 18,
          "maximum": 28,
          "multipleOf": 0.5
        },
        "humidity": {
          "type": "integer",
          "minimum": 30,
          "maximum": 70,
          "multipleOf": 5
        },
        "strategy": {
          "enum": [
            "soft",
            "normal",
            "aggressive"
          ]
        }
      }
    },
    "contour_reason": {
      "enum": [
        "room_state_unavailable",
        "state_stale",
        "device_unavailable",
        "engine_not_automatic",
        "authority_not_ready",
        "target_temperature_differs",
        "target_humidity_differs",
        "target_strategy_unavailable",
        "target_strategy_differs"
      ]
    },
    "contour_room": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "current",
        "targets",
        "comfort_profiles",
        "temporary_temperature",
        "device_count",
        "engine_mode",
        "engine_strategy",
        "authority_ready",
        "targets_in_sync",
        "automatic_active",
        "reasons"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "status": {
          "enum": [
            "ready",
            "unavailable"
          ]
        },
        "current": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "temperature",
            "humidity"
          ],
          "properties": {
            "temperature": {
              "$ref": "#/$defs/nullable_number"
            },
            "humidity": {
              "$ref": "#/$defs/nullable_number"
            }
          }
        },
        "targets": {
          "$ref": "#/$defs/comfort_values"
        },
        "comfort_profiles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "active",
            "day",
            "night"
          ],
          "properties": {
            "active": {
              "enum": [
                "day",
                "night"
              ]
            },
            "day": {
              "$ref": "#/$defs/comfort_values"
            },
            "night": {
              "$ref": "#/$defs/comfort_values"
            }
          }
        },
        "temporary_temperature": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "active",
            "temperature",
            "ends",
            "available"
          ],
          "properties": {
            "active": {
              "type": "boolean"
            },
            "temperature": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 18,
              "maximum": 28,
              "multipleOf": 0.5
            },
            "ends": {
              "type": [
                "string",
                "null"
              ],
              "enum": [
                "next_schedule_change",
                null
              ]
            },
            "available": {
              "type": "boolean"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "active": {
                    "const": true
                  }
                }
              },
              "then": {
                "properties": {
                  "temperature": {
                    "type": "number"
                  },
                  "ends": {
                    "const": "next_schedule_change"
                  }
                }
              },
              "else": {
                "properties": {
                  "temperature": {
                    "type": "null"
                  },
                  "ends": {
                    "type": "null"
                  }
                }
              }
            }
          ]
        },
        "device_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 512
        },
        "engine_mode": {
          "enum": [
            "automatic",
            "manual",
            "unknown"
          ]
        },
        "engine_strategy": {
          "enum": [
            "soft",
            "normal",
            "aggressive",
            "unknown"
          ]
        },
        "authority_ready": {
          "type": "boolean"
        },
        "targets_in_sync": {
          "type": "boolean"
        },
        "automatic_active": {
          "type": "boolean"
        },
        "reasons": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/contour_reason"
          }
        }
      }
    },
    "contour": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "kind",
        "mode",
        "status",
        "engine",
        "schedule",
        "rooms",
        "execution",
        "reasons"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/stable_id"
        },
        "name": {
          "$ref": "#/$defs/name"
        },
        "kind": {
          "const": "climate"
        },
        "mode": {
          "enum": [
            "disabled",
            "observe",
            "automatic"
          ]
        },
        "status": {
          "enum": [
            "disabled",
            "ready",
            "attention",
            "unavailable",
            "stale"
          ]
        },
        "engine": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "const": "hausman-climate"
            },
            "version": {
              "const": 1
            }
          }
        },
        "schedule": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "day_start",
            "night_start"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "day_start": {
              "type": "string",
              "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$"
            },
            "night_start": {
              "type": "string",
              "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$"
            }
          }
        },
        "rooms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/contour_room"
          }
        },
        "execution": {
          "$ref": "#/$defs/contour_execution"
        },
        "reasons": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/contour_reason"
          }
        }
      }
    },
    "contour_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "automatic_active",
        "hausmanhub_direct_commands",
        "settings_apply",
        "temporary_temperature"
      ],
      "properties": {
        "owner": {
          "const": "existing_climate_core"
        },
        "automatic_active": {
          "type": "boolean"
        },
        "hausmanhub_direct_commands": {
          "const": false
        },
        "settings_apply": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "available",
            "requires_confirmation",
            "parameters"
          ],
          "properties": {
            "available": {
              "type": "boolean"
            },
            "requires_confirmation": {
              "const": true
            },
            "parameters": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "temperature",
                "strategy",
                "automatic_mode",
                "humidity"
              ],
              "properties": {
                "temperature": {
                  "const": true
                },
                "strategy": {
