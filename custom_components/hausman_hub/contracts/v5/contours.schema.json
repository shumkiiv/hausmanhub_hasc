{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hausman.local/hasc/contracts/v5/contours.schema.json",
  "title": "HASC automatic contours v5",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "contours"],
  "properties": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "hausman-hasc-contours"},
        "version": {"const": 5}
      }
    },
    "contours": {
      "type": "array",
      "maxItems": 32,
      "items": {"$ref": "#/$defs/contour"}
    }
  },
  "$defs": {
    "stableId": {"type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$"},
    "nullableNumber": {"type": ["number", "null"]},
    "reason": {
      "enum": ["room_state_unavailable", "state_stale", "device_unavailable", "engine_not_automatic", "authority_not_ready", "target_temperature_differs", "target_humidity_differs", "target_strategy_unavailable", "target_strategy_differs"]
    },
    "comfortValues": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperature", "humidity", "strategy"],
      "properties": {
        "temperature": {"type": "number", "minimum": 18, "maximum": 28, "multipleOf": 0.5},
        "humidity": {"type": "integer", "minimum": 30, "maximum": 70, "multipleOf": 5},
        "strategy": {"enum": ["soft", "normal", "aggressive"]}
      }
    },
    "contour": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "mode", "status", "engine", "schedule", "rooms", "execution", "reasons"],
      "properties": {
        "id": {"$ref": "#/$defs/stableId"},
        "name": {"type": "string", "minLength": 1, "maxLength": 120},
        "kind": {"const": "climate"},
        "mode": {"enum": ["disabled", "observe", "automatic"]},
        "status": {"enum": ["disabled", "ready", "attention", "unavailable", "stale"]},
        "engine": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"const": "hausman-climate"},
            "version": {"const": 1}
          }
        },
        "schedule": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "day_start", "night_start"],
          "properties": {
            "enabled": {"type": "boolean"},
            "day_start": {"type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$"},
            "night_start": {"type": "string", "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]$"}
          }
        },
        "rooms": {"type": "array", "minItems": 1, "maxItems": 128, "items": {"$ref": "#/$defs/room"}},
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "automatic_active", "hasc_direct_commands", "settings_apply", "temporary_temperature"],
          "properties": {
            "owner": {"const": "existing_climate_core"},
            "automatic_active": {"type": "boolean"},
            "hasc_direct_commands": {"const": false},
            "settings_apply": {
              "type": "object",
              "additionalProperties": false,
              "required": ["available", "requires_confirmation", "parameters"],
              "properties": {
                "available": {"type": "boolean"},
                "requires_confirmation": {"const": true},
                "parameters": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["temperature", "strategy", "automatic_mode", "humidity"],
                  "properties": {
                    "temperature": {"const": true},
                    "strategy": {"const": true},
                    "automatic_mode": {"const": true},
                    "humidity": {"const": false}
                  }
                }
              }
            },
            "temporary_temperature": {
              "type": "object",
              "additionalProperties": false,
              "required": ["available", "requires_confirmation", "minimum", "maximum", "step"],
              "properties": {
                "available": {"type": "boolean"},
                "requires_confirmation": {"const": true},
                "minimum": {"const": 18.0},
                "maximum": {"const": 28.0},
                "step": {"const": 0.5}
              }
            }
          }
        },
        "reasons": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/reason"}}
      }
    },
    "room": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "status", "current", "targets", "comfort_profiles", "temporary_temperature", "device_count", "engine_mode", "engine_strategy", "authority_ready", "targets_in_sync", "automatic_active", "reasons"],
      "properties": {
        "id": {"$ref": "#/$defs/stableId"},
        "name": {"type": "string", "minLength": 1, "maxLength": 120},
        "status": {"enum": ["ready", "unavailable"]},
        "current": {
          "type": "object",
          "additionalProperties": false,
          "required": ["temperature", "humidity"],
          "properties": {
            "temperature": {"$ref": "#/$defs/nullableNumber"},
            "humidity": {"$ref": "#/$defs/nullableNumber"}
          }
        },
        "targets": {"$ref": "#/$defs/comfortValues"},
        "comfort_profiles": {
          "type": "object",
          "additionalProperties": false,
          "required": ["active", "day", "night"],
          "properties": {
            "active": {"enum": ["day", "night"]},
            "day": {"$ref": "#/$defs/comfortValues"},
            "night": {"$ref": "#/$defs/comfortValues"}
          }
        },
        "temporary_temperature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["active", "temperature", "ends", "available"],
          "properties": {
            "active": {"type": "boolean"},
            "temperature": {"type": ["number", "null"], "minimum": 18, "maximum": 28, "multipleOf": 0.5},
            "ends": {"type": ["string", "null"], "enum": ["next_schedule_change", null]},
            "available": {"type": "boolean"}
          },
          "allOf": [
            {
              "if": {"properties": {"active": {"const": true}}},
              "then": {
                "properties": {
                  "temperature": {"type": "number"},
                  "ends": {"const": "next_schedule_change"}
                }
              },
              "else": {
                "properties": {
                  "temperature": {"type": "null"},
                  "ends": {"type": "null"}
                }
              }
            }
          ]
        },
        "device_count": {"type": "integer", "minimum": 1, "maximum": 512},
        "engine_mode": {"type": ["string", "null"], "enum": ["auto", "manual", "forced_auto_only", null]},
        "engine_strategy": {"type": ["string", "null"], "enum": ["soft", "normal", "aggressive", null]},
        "authority_ready": {"type": "boolean"},
        "targets_in_sync": {"type": "boolean"},
        "automatic_active": {"type": "boolean"},
        "reasons": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/reason"}}
      }
    }
  }
}
